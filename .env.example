# Copy this file to .env.local and fill in real values.
# .env.local is gitignored (matches the *.local pattern) - never commit real secrets.

# Used to sign session tokens issued by /api/login. Any long random string.
SESSION_SECRET=

# --- Advantage Services sub-account ---
ADVANTAGE_USERNAME=
ADVANTAGE_PASSWORD=
ADVANTAGE_GHL_LOCATION_ID=
ADVANTAGE_GHL_TOKEN=
ADVANTAGE_GHL_PIPELINE_ID=
ADVANTAGE_GHL_CALENDAR_ID=

# --- KGB Marketing sub-account ---
KGB_USERNAME=
KGB_PASSWORD=
KGB_GHL_LOCATION_ID=
KGB_GHL_TOKEN=
KGB_GHL_PIPELINE_ID=
KGB_GHL_CALENDAR_ID=
